// ─── ARUNA domain tables (managed by Prisma db push) ───

model aruna_users {
  uid           String  @id
  name          String
  email         String
  role          String?
  associated_id String?
  address       String?

  @@map("aruna_users")
}

model aruna_buyers {
  id            Int       @id @default(autoincrement())
  slug          String?   @unique
  company_name  String
  city          String
  industry      String
  nib           String?
  siup          String?
  verified      Boolean?  @default(false)
  buyer_type    String?
  address       String?
  created_at    DateTime? @db.Timestamptz(6)

  market_requests aruna_market_requests[]

  @@map("aruna_buyers")
}

model aruna_market_requests {
  id               Int      @id @default(autoincrement())
  buyer_id         Int
  commodity_name   String
  quantity         Decimal  @db.Decimal(12, 2)
  unit             String
  status           String
  created_at       DateTime? @db.Timestamptz(6)
  shipping_address String?
  invoice_number   String?
  coop_name        String?
  total_price      Decimal? @db.Decimal(14, 2)

  buyer          aruna_buyers          @relation(fields: [buyer_id], references: [id], onDelete: Restrict)
  supply_matches aruna_supply_matches[]

  @@index([buyer_id])
  @@map("aruna_market_requests")
}

model aruna_supply_matches {
  id                 Int      @id @default(autoincrement())
  request_id         Int
  cooperative_id     String
  allocated_quantity Decimal  @db.Decimal(12, 2)
  matched_at         DateTime? @db.Timestamptz(6)

  request aruna_market_requests @relation(fields: [request_id], references: [id], onDelete: Restrict)

  @@unique([request_id, cooperative_id])
  @@index([request_id])
  @@index([cooperative_id])
  @@map("aruna_supply_matches")
}

model aruna_cooperative_scores {
  cooperative_id String   @id
  health_score   Decimal  @db.Decimal(5, 2)
  growth_score   Decimal  @db.Decimal(5, 2)
  supply_score   Decimal  @db.Decimal(5, 2)
  final_score    Decimal  @db.Decimal(5, 2)
  grade          String
  updated_at     DateTime? @db.Timestamptz(6)

  @@map("aruna_cooperative_scores")
}

model aruna_insights {
  id              Int      @id @default(autoincrement())
  cooperative_id  String?
  title           String
  description     String   @db.Text
  recommendation  String   @db.Text
  severity        String
  created_at      DateTime? @db.Timestamptz(6)

  @@index([cooperative_id])
  @@map("aruna_insights")
}
